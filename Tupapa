-- [[ PARRA NINJA HUB - RED & BLACK ELITE FULL EDITION 👑 ]]
local CLAVE_CORRECTA = "papadeacusado"
local Players = game:GetService("Players")
local L_Plr = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local Mouse = L_Plr:GetMouse()

-- // SEGURIDAD ANTI-BAN //
local function RandomName()
    local str = ""
    for i = 1, 15 do str = str .. string.char(math.random(65, 90)) end
    return str
end

local function CheckForMods(plt)
    if plt:GetRankInGroup(0) > 200 or plt.CharacterAppearanceId == 1 then 
        L_Plr:Kick("\n[PARRA SAFE]\nModerador Detectado: " .. plt.Name)
    end
end
Players.PlayerAdded:Connect(function(plt) if _G.AutoLeave then CheckForMods(plt) end end)

local function GetSafeParent()
    local success, parent = pcall(function() return (gethui and gethui()) or game:GetService("CoreGui") end)
    return success and parent or L_Plr:FindFirstChild("PlayerGui")
end

local function ExecuteHub()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = RandomName()
    ScreenGui.Parent = GetSafeParent()
    ScreenGui.ResetOnSpawn = false

    -- // VARIABLES GLOBALES //
    _G.Hitbox_Size = 15
    _G.Parts_Active = {Head = false, UpperTorso = false, Torso = false, LeftHand = false, RightHand = false, LeftFoot = false, RightFoot = false}
    _G.Box_Enabled = false; _G.Names_Enabled = false; _G.Inv_Enabled = false; _G.Tracer_Enabled = false
    _G.AuxilioMobile = false; _G.AutoLeave = true

    -- // LÓGICA HITBOX (CABEZA SIEMPRE INVISIBLE) //
    task.spawn(function()
        while task.wait(0.5) do
            pcall(function()
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= L_Plr and p.Character then
                        for partName, isEnabled in pairs(_G.Parts_Active) do
                            local part = p.Character:FindFirstChild(partName)
                            if part and part:IsA("BasePart") then
                                if isEnabled then
                                    part.Size = Vector3.new(_G.Hitbox_Size, _G.Hitbox_Size, _G.Hitbox_Size)
                                    part.Transparency = 1 -- Invisible para seguridad
                                    part.CanCollide = false
                                    part.Massless = true
                                else
                                    local defaultSize = (partName == "Head" and Vector3.new(2,1,1) or Vector3.new(2,2,1))
                                    if part.Size ~= defaultSize then
                                        part.Size = defaultSize
                                        part.Transparency = 0
                                        part.CanCollide = true
                                        part.Massless = false
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    end)

    -- // ESP OUTLINE (FIXED PARA NUEVOS JUGADORES) //
    local function CreateESP(plt)
        if plt == L_Plr then return end
        local Box = Drawing.new("Square"); Box.Thickness = 1.5; Box.Filled = false; Box.Visible = false; Box.Color = Color3.fromRGB(255, 0, 0)
        local NameTag = Drawing.new("Text"); NameTag.Size = 14; NameTag.Outline = true; NameTag.Visible = false; NameTag.Color = Color3.new(1,1,1)
        local InvTag = Drawing.new("Text"); InvTag.Size = 13; InvTag.Outline = true; InvTag.Visible = false; InvTag.Color = Color3.fromRGB(0, 255, 0)
        local Tracer = Drawing.new("Line"); Tracer.Thickness = 1; Tracer.Visible = false; Tracer.Color = Color3.fromRGB(255, 0, 0)
        
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if not plt.Parent then Box:Remove(); NameTag:Remove(); InvTag:Remove(); Tracer:Remove(); connection:Disconnect() return end
            pcall(function()
                if plt.Character and plt.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = plt.Character.HumanoidRootPart
                    local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                    if onScreen then
                        local sizeX, sizeY = 2000/pos.Z, 3000/pos.Z
                        Box.Visible = _G.Box_Enabled; Box.Size = Vector2.new(sizeX, sizeY); Box.Position = Vector2.new(pos.X - sizeX/2, pos.Y - sizeY/2)
                        Tracer.Visible = _G.Tracer_Enabled; Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, 0); Tracer.To = Vector2.new(pos.X, pos.Y - sizeY/2)
                        if _G.Names_Enabled then NameTag.Text = plt.Name; NameTag.Position = Vector2.new(pos.X, pos.Y - (sizeY/2) - 15); NameTag.Visible = true else NameTag.Visible = false end
                        if _G.Inv_Enabled then
                            local w = "NADA"; for _, t in pairs(plt.Character:GetChildren()) do if t:IsA("Tool") then w = t.Name break end end
                            InvTag.Text = "ARMA: " .. w:upper(); InvTag.Position = Vector2.new(pos.X, pos.Y + (sizeY/2) + 5); InvTag.Visible = true
                        else InvTag.Visible = false end
                    else Box.Visible = false; NameTag.Visible = false; InvTag.Visible = false; Tracer.Visible = false end
                else Box.Visible = false; NameTag.Visible = false; InvTag.Visible = false; Tracer.Visible = false end
            end)
        end)
    end
    for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
    Players.PlayerAdded:Connect(CreateESP)

    -- // INTERFAZ BOTÓN FLOTANTE //
    local OpenBtn = Instance.new("TextButton", ScreenGui); OpenBtn.Size = UDim2.new(0, 50, 0, 50); OpenBtn.Position = UDim2.new(0, 15, 0.5, 0); OpenBtn.BackgroundColor3 = Color3.fromRGB(20, 0, 0); OpenBtn.Text = "N"; OpenBtn.TextColor3 = Color3.new(1,0,0); OpenBtn.TextSize = 25; OpenBtn.Visible = false; OpenBtn.Active = true; OpenBtn.Draggable = true; Instance.new("UICorner", OpenBtn).CornerRadius = UDim.new(1, 0); Instance.new("UIStroke", OpenBtn).Color = Color3.new(1,0,0)

    -- // LOGIN //
    local KeyFrame = Instance.new("Frame", ScreenGui); KeyFrame.Size = UDim2.new(0, 400, 0, 250); KeyFrame.Position = UDim2.new(0.5, -200, 0.5, -125); KeyFrame.BackgroundColor3 = Color3.fromRGB(5, 5, 5); KeyFrame.Active = true; KeyFrame.Draggable = true; Instance.new("UICorner", KeyFrame); Instance.new("UIStroke", KeyFrame).Color = Color3.fromRGB(150, 0, 0)
    local KeyTitle = Instance.new("TextLabel", KeyFrame); KeyTitle.Size = UDim2.new(1, 0, 0, 80); KeyTitle.Text = "PARRA NINJA HUB\nINGRESE CLAVE"; KeyTitle.TextColor3 = Color3.new(1,0,0); KeyTitle.BackgroundTransparency = 1; KeyTitle.Font = Enum.Font.Code; KeyTitle.TextSize = 18
    local KeyInput = Instance.new("TextBox", KeyFrame); KeyInput.Size = UDim2.new(0, 280, 0, 50); KeyInput.Position = UDim2.new(0.5, -140, 0.45, 0); KeyInput.PlaceholderText = "••••••••"; KeyInput.Text = ""; KeyInput.BackgroundColor3 = Color3.fromRGB(15,0,0); KeyInput.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", KeyInput)
    local KeyBtn = Instance.new("TextButton", KeyFrame); KeyBtn.Size = UDim2.new(0, 180, 0, 45); KeyBtn.Position = UDim2.new(0.5, -90, 0.75, 0); KeyBtn.Text = "LOG IN"; KeyBtn.BackgroundColor3 = Color3.fromRGB(30, 0, 0); KeyBtn.TextColor3 = Color3.new(1,1,1); KeyBtn.Font = Enum.Font.Code; Instance.new("UICorner", KeyBtn)

    -- // MENÚ //
    local MainFrame = Instance.new("Frame", ScreenGui); MainFrame.Size = UDim2.new(0, 560, 0, 480); MainFrame.Position = UDim2.new(0.5, -280, 0.5, -240); MainFrame.BackgroundColor3 = Color3.fromRGB(10, 0, 0); MainFrame.Visible = false; MainFrame.Active = true; MainFrame.Draggable = true; Instance.new("UICorner", MainFrame); Instance.new("UIStroke", MainFrame).Color = Color3.fromRGB(200, 0, 0)
    local Banner = Instance.new("TextLabel", MainFrame); Banner.Size = UDim2.new(1, 0, 0, 50); Banner.Text = "PARRA NINJA HUB | ELITE"; Banner.TextColor3 = Color3.new(1,0,0); Banner.BackgroundTransparency = 1; Banner.Font = Enum.Font.Code; Banner.TextSize = 14

    KeyBtn.MouseButton1Click:Connect(function()
        if KeyInput.Text == CLAVE_CORRECTA then KeyFrame.Visible = false; MainFrame.Visible = true 
        else KeyInput.Text = ""; KeyInput.PlaceholderText = "CLAVE MALA" end
    end)
    OpenBtn.MouseButton1Click:Connect(function() MainFrame.Visible = true; OpenBtn.Visible = false end)

    -- // TABS //
    local Container = Instance.new("Frame", MainFrame); Container.Position = UDim2.new(0, 160, 0, 60); Container.Size = UDim2.new(1, -170, 1, -70); Container.BackgroundTransparency = 1
    local Tabs = { Combat = Instance.new("ScrollingFrame"), Visuals = Instance.new("ScrollingFrame"), Farm = Instance.new("ScrollingFrame"), Misc = Instance.new("ScrollingFrame") }
    for name, frame in pairs(Tabs) do frame.Size = UDim2.new(1, 0, 1, 0); frame.BackgroundTransparency = 1; frame.Visible = (name == "Combat"); frame.Parent = Container; frame.ScrollBarThickness = 0; Instance.new("UIListLayout", frame).Padding = UDim.new(0, 10) end

    local function AddBtn(parent, text, func)
        local b = Instance.new("TextButton", parent); b.Size = UDim2.new(1, -10, 0, 40); b.BackgroundColor3 = Color3.fromRGB(25, 0, 0); b.Text = text; b.TextColor3 = Color3.new(1,1,1); b.Font = Enum.Font.Code; b.TextSize = 13; Instance.new("UICorner", b); Instance.new("UIStroke", b).Color = Color3.fromRGB(100,0,0)
        b.MouseButton1Click:Connect(func)
    end

    -- Combat Tab
    AddBtn(Tabs.Combat, "AUTO-LEAVE PARRA", function() _G.AutoLeave = not _G.AutoLeave end)
    AddBtn(Tabs.Combat, "AUXILIO DISPARO", function() _G.AuxilioMobile = not _G.AuxilioMobile end)
    AddBtn(Tabs.Combat, "LOAD AIMBOT MOBILE", function() loadstring(game:HttpGet("https://raw.githubusercontent.com/scripting-star/Aimbot-V1-Premium/refs/heads/main/Aim-v1.01"))() end)
    local HitInput = Instance.new("TextBox", Tabs.Combat); HitInput.Size = UDim2.new(1, -10, 0, 40); HitInput.PlaceholderText = "TAMAÑO HITBOX (15)"; HitInput.BackgroundColor3 = Color3.fromRGB(30,0,0); HitInput.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", HitInput)
    HitInput.FocusLost:Connect(function() _G.Hitbox_Size = tonumber(HitInput.Text) or 15 end)
    AddBtn(Tabs.Combat, "HITBOX: CABEZA", function() _G.Parts_Active.Head = not _G.Parts_Active.Head end)
    AddBtn(Tabs.Combat, "HITBOX: TORSO", function() _G.Parts_Active.Torso = not _G.Parts_Active.Torso; _G.Parts_Active.UpperTorso = _G.Parts_Active.Torso end)
    AddBtn(Tabs.Combat, "HITBOX: BRAZOS", function() _G.Parts_Active.LeftHand = not _G.Parts_Active.LeftHand; _G.Parts_Active.RightHand = _G.Parts_Active.LeftHand end)
    AddBtn(Tabs.Combat, "HITBOX: PIERNAS", function() _G.Parts_Active.LeftFoot = not _G.Parts_Active.LeftFoot; _G.Parts_Active.RightFoot = _G.Parts_Active.LeftFoot end)

    -- Visuals Tab
    AddBtn(Tabs.Visuals, "NOMBRE ESP", function() _G.Names_Enabled = not _G.Names_Enabled end)
    AddBtn(Tabs.Visuals, "BOX ESP (OUTLINE)", function() _G.Box_Enabled = not _G.Box_Enabled end)
    AddBtn(Tabs.Visuals, "VER ARMA ENEMIGA", function() _G.Inv_Enabled = not _G.Inv_Enabled end)
    AddBtn(Tabs.Visuals, "TRACERS", function() _G.Tracer_Enabled = not _G.Tracer_Enabled end)

    -- Farm Tab
    AddBtn(Tabs.Farm, "EJECUTAR AUTOFARM", function() loadstring(game:HttpGet("https://raw.githubusercontent.com/scriptparra-ui/SCRIPT-PARRA/refs/heads/main/Pirata"))() end)

    -- Misc Tab
    AddBtn(Tabs.Misc, "FPS ANTI-LAG", function() for _,v in pairs(workspace:GetDescendants()) do if v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic end end end)
    AddBtn(Tabs.Misc, "DELETE PARRA (FIXED)", function() 
        local t = Instance.new("Tool"); t.Name = "ACUSADO_DEL"; t.RequiresHandle = false; t.Parent = L_Plr.Backpack
        t.Activated:Connect(function() if Mouse.Target then Mouse.Target:Destroy() end end)
    end)

    local Sidebar = Instance.new("Frame", MainFrame); Sidebar.Size = UDim2.new(0, 140, 1, -60); Sidebar.Position = UDim2.new(0, 5, 0, 55); Sidebar.BackgroundTransparency = 1
    local function AddTab(txt, target, y)
        local b = Instance.new("TextButton", Sidebar); b.Size = UDim2.new(1, -10, 0, 45); b.Position = UDim2.new(0, 5, 0, y); b.BackgroundColor3 = Color3.fromRGB(20, 0, 0); b.Text = txt; b.TextColor3 = Color3.new(1,0,0); b.Font = Enum.Font.Code; Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function() for _, t in pairs(Tabs) do t.Visible = false end; Tabs[target].Visible = true end)
    end
    AddTab("COMBATE", "Combat", 0); AddTab("VISUALES", "Visuals", 55); AddTab("AUTOFARM", "Farm", 110); AddTab("SISTEMA", "Misc", 165)

    local CloseBtn = Instance.new("TextButton", MainFrame); CloseBtn.Size = UDim2.new(0, 30, 0, 30); CloseBtn.Position = UDim2.new(1, -38, 0, 8); CloseBtn.Text = "X"; CloseBtn.BackgroundColor3 = Color3.fromRGB(150,0,0); CloseBtn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", CloseBtn)
    CloseBtn.MouseButton1Click:Connect(function() MainFrame.Visible = false; OpenBtn.Visible = true end)
end

pcall(ExecuteHub)
