-- ==================== JOSTIN TOL (DELETE + NOCLIP) ====================
local function createJostinTol()
    if player.Backpack:FindFirstChild("JOSTIN TOL") or (player.Character and player.Character:FindFirstChild("JOSTIN TOL")) then
        print("JOSTIN TOL ya existe")
        return
    end

    local tool = Instance.new("Tool")
    tool.Name = "JOSTIN TOL"
    tool.RequiresHandle = false
    tool.Parent = player.Backpack

    local noclipEnabled = false
    local noclipConnection = nil

    tool.Equipped:Connect(function()
        print("✅ JOSTIN TOL equipado")
        print("• Clic Izquierdo = Borrar objeto")
        print("• Clic Derecho mantenido = Traspasar (Noclip)")

        noclipConnection = game:GetService("RunService").RenderStepped:Connect(function()
            if noclipEnabled and player.Character then
                for _, part in ipairs(player.Character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end)

    tool.Unequipped:Connect(function()
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
        -- Restaurar colisiones
        if player.Character then
            for _, part in ipairs(player.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
        noclipEnabled = false
    end)

    -- Clic izquierdo = Borrar
    tool.Activated:Connect(function()
        local mouse = player:GetMouse()
        local target = mouse.Target
        if target and target.Parent and not target:IsA("Terrain") then
            target:Destroy()
            print("[JOSTIN TOL] Borrado → " .. target.Name)
        end
    end)

    -- Clic derecho = Toggle Noclip
    local mouse = player:GetMouse()
    mouse.Button2Down:Connect(function()
        if tool.Parent == player.Character then
            noclipEnabled = not noclipEnabled
            print("JOSTIN TOL Noclip: " .. (noclipEnabled and "ON" or "OFF"))
        end
    end)

    print("✅ JOSTIN TOL creado y agregado al inventario")
end

-- ==================== BOTÓN ACTIVAR DELETE ====================
deleteBtn.MouseButton1Click:Connect(function()
    createJostinTol()
    statusLabel.Text = "Anti-Ban: Activado | JOSTIN TOL activado"
end)

-- ==================== KEY VERIFICATION ====================
local function verifyKey()
    if keyBox.Text:upper() == CORRECT_KEY then
        keyStatus.Text = "Key correcta ✓"
        keyStatus.TextColor3 = Color3.fromRGB(0, 255, 100)
        
        task.wait(1)
        keyFrame:Destroy()
        
        toggleBtn.Visible = true
        mainFrame.Visible = true
        statusLabel.Text = "Anti-Ban: Activado"
        
        print("✅ Panel cargado - Usa el botón 'ACTIVAR DELETE' para obtener JOSTIN TOL")
    else
        keyStatus.Text = "Key incorrecta"
        keyStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        keyBox.Text = ""
    end
end

submitBtn.MouseButton1Click:Connect(verifyKey)
keyBox.FocusLost:Connect(function(enter) if enter then verifyKey() end end)

-- ==================== TOGGLE PANEL ====================
local function togglePanel()
    local isOpen = mainFrame.Visible
    mainFrame.Visible = not isOpen
    
    if not isOpen then
        statusLabel.Text = "Anti-Ban: Activado"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        toggleBtn.Text = "X"
    else
        toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
        toggleBtn.Text = "SB"
    end
end

toggleBtn.MouseButton1Click:Connect(togglePanel)

-- Drag toggle
local dragging = false
local dragStart, startPos

toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = toggleBtn.Position
    end
end)

toggleBtn.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        toggleBtn.Position = UDim2.new(0, startPos.X.Offset + delta.X, 0, startPos.Y.Offset + delta.Y)
    end
end)

toggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Auto ajustar scroll
uiListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, uiListLayout.AbsoluteContentSize.Y + 60)
end)

-- ==================== FARM FUNCIONES ====================
local farming = false
local farmCoroutine = nil
local totalCash = 0
local lastMoney = 0

local function updateMoney()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local stat = leaderstats:FindFirstChild("Cash") or leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Dinero")
        if stat then
            local current = stat.Value
            local gained = current - lastMoney
            if gained > 0 then
                totalCash = totalCash + gained
                moneyLabel.Text = "CASH TOTAL: $" .. totalCash
            end
            lastMoney = current
        end
    end
end

local function autoSelectItems()
    statusLabel.Text = "Anti-Ban: Activado"
    print("[AUTO ITEM] Ejecutado")
end

local function startFarming()
    if farmCoroutine then return end
    farming = true
    farmeoBtn.Text = "FARME O: ON"
    farmeoBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    statusLabel.Text = "Anti-Ban: Activado"

    farmCoroutine = task.spawn(function()
        while farming do
            updateMoney()
            task.wait(1)
        end
    end)
end

local function stopFarming()
    farming = false
    if farmCoroutine then task.cancel(farmCoroutine) end
    farmCoroutine = nil
    farmeoBtn.Text = "FARME O: OFF"
    farmeoBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    statusLabel.Text = "Anti-Ban: Activado"
end

autoItemBtn.MouseButton1Click:Connect(autoSelectItems)
farmeoBtn.MouseButton1Click:Connect(function()
    if farming then stopFarming() else startFarming() end
end)

-- Update loop
task.spawn(function()
    while task.wait(1) do
        if mainFrame.Visible then
            updateMoney()
        end
    end
end)

print("✅ v2.5 cargado correctamente")
print("Key: JOSTIN")
print("Nuevo botón 'ACTIVAR DELETE' agregado en el panel
